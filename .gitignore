# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
*.so
*.dylib

# Virtual environments
venv/
env/
.venv/
.env

# Keep .env.example (tracked), but ignore real .env
.env
!.env.example

# Logs (generated at runtime — do not track)
logs/*.csv
logs/reports/
!logs/.gitkeep

# Trained model files (often too large for git)
src/models/*.pkl
src/models/*.h5
src/models/*.json
src/models/*.npy
!src/models/__init__.py

# Numpy data files
*.npy

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Node / React
frontend/node_modules/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml

# Test coverage
.coverage
htmlcov/
.pytest_cache/
